# extract-api environment. Copy to .env and fill in. NEVER commit .env.
# The whole point of the llm/client.py seam: provider routing is env-only, so the
# week-10 gateway migration is just repointing LLM_BASE_URL + LLM_API_KEY.

# --- LLM routing (the gateway seam) ---
# Default provider when the request says "default". Both providers now have real call
# paths (OpenAI Responses API, Anthropic Messages API); openai stays the default.
LLM_DEFAULT_PROVIDER=openai

# Base URL + key the active provider client is constructed with. Point these at the
# gateway virtual key in week 10. In gateway (non-bypass) mode BOTH are REQUIRED: the
# client fails loud if either is unset, so a half-config can never silently fall back to
# an ambient provider key + the provider's public endpoint (issue #38).
LLM_BASE_URL=
LLM_API_KEY=

# Escape hatch: 1 = bypass the gateway and talk to the provider directly with the
# per-provider key below (OPENAI_API_KEY / ANTHROPIC_API_KEY). This is the default until
# the gateway exists; unset it (or set != 1) only once LLM_BASE_URL + LLM_API_KEY point
# at a real gateway.
GATEWAY_BYPASS=1

# Concrete model ids per provider (verify against provider docs at build time).
OPENAI_MODEL=gpt-5.1
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-provider credentials (used only when not routing through the gateway).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Cost accounting ---
# Per-million-token prices (USD) for the ACTIVE model of each provider. REQUIRED and
# explicit for the provider you call: there is no default, because defaulting would bill
# every model at one rate and report a wrong cost_usd. Set these to the list prices of
# your OPENAI_MODEL / ANTHROPIC_MODEL. (Only the active provider's prices are read, so
# leaving the unused provider's blank is fine.)
OPENAI_PRICE_IN_PER_M=
OPENAI_PRICE_OUT_PER_M=
ANTHROPIC_PRICE_IN_PER_M=
ANTHROPIC_PRICE_OUT_PER_M=

# --- Provider call bounds ---
# Per-request timeout (seconds) and transport retry cap, so the synchronous API
# cannot pin a worker on a slow provider (the SDK default read timeout is ~600s).
LLM_REQUEST_TIMEOUT_S=60
LLM_MAX_RETRIES=2

# --- Budget guard (M3) ---
# Hard per-run USD cap; exceeding it raises budget_exceeded.
EXTRACT_BUDGET_USD=1.00

# --- Idempotency store (ADR 0004: SQLite for v1) ---
IDEMPOTENCY_DB_PATH=idempotency.sqlite
IDEMPOTENCY_TTL_HOURS=24

# --- Provider mode for deterministic local smoke + tests (no paid calls) ---
# fixture = use the in-process FixtureClient (canned output). Leave unset in prod.
LLM_PROVIDER_MODE=
