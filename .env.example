# extract-api environment. Copy to .env and fill in. NEVER commit .env.
# The whole point of the llm/client.py seam: provider routing is env-only, so the
# week-10 gateway migration is just repointing LLM_BASE_URL + LLM_API_KEY.

# --- LLM routing (the gateway seam) ---
# Default provider when the request says "default".
LLM_DEFAULT_PROVIDER=anthropic

# Base URL + key the active provider client is constructed with. Point these at a
# provider directly now; point them at the gateway virtual key in week 10.
LLM_BASE_URL=
LLM_API_KEY=

# Escape hatch: 1 = bypass the gateway and talk to the provider directly.
GATEWAY_BYPASS=1

# Concrete model ids per provider (verify against provider docs at build time).
OPENAI_MODEL=gpt-5.1
ANTHROPIC_MODEL=claude-sonnet-4-6

# Per-provider credentials (used only when not routing through the gateway).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Budget guard (M3) ---
# Hard per-run USD cap; exceeding it raises budget_exceeded.
EXTRACT_BUDGET_USD=1.00

# --- Idempotency store (ADR 0004: SQLite for v1) ---
IDEMPOTENCY_DB_PATH=idempotency.sqlite
IDEMPOTENCY_TTL_HOURS=24

# --- Provider mode for deterministic local smoke + tests (no paid calls) ---
# fixture = use the in-process FixtureClient (canned output). Leave unset in prod.
LLM_PROVIDER_MODE=
